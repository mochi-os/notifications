{
	"version": "3.48",
	"label": "app.name",
	"paths": ["notifications"],
	"services": ["notifications"],

	"architecture": {"engine": "starlark", "version": 4},
	"execute": ["notifications.star"],

	"database": {
		"schema": 24,
		"file": "notifications.db",
		"create": {"function": "database_create"},
		"upgrade": {"function": "database_upgrade"},
		"downgrade": {"function": "database_downgrade"},
		"replicate": {
			"exclude": {
				"tables": ["push_pending"]
			}
		}
	},

	"actions": {
		"": {"file": "web/dist/index.html"},
		"assets": {"files": "web/dist/assets"},
		"images": {"files": "web/dist/images"},
		"-/list": {"function": "action_list"},
		"-/count": {"function": "action_count"},
		"-/read": {"function": "action_read"},
		"-/read/all": {"function": "action_read_all"},
		"-/clear/all": {"function": "action_clear_all"},
		"-/rss": {"function": "action_rss", "public": true},
		"-/rss/list": {"function": "action_rss_list"},
		"-/rss/create": {"function": "action_rss_create"},
		"-/rss/delete": {"function": "action_rss_delete"},
		"-/rss/rename": {"function": "action_rss_rename"},
		"-/rss/update": {"function": "action_rss_update"},
		"-/accounts/providers": {"function": "action_accounts_providers"},
		"-/accounts/list": {"function": "action_accounts_list"},
		"-/accounts/get": {"function": "action_accounts_get"},
		"-/accounts/add": {"function": "action_accounts_add"},
		"-/accounts/update": {"function": "action_accounts_update"},
		"-/accounts/remove": {"function": "action_accounts_remove"},
		"-/accounts/verify": {"function": "action_accounts_verify"},
		"-/accounts/vapid": {"function": "action_accounts_vapid"},
		"-/categories/list": {"function": "action_categories_list"},
		"-/categories/create": {"function": "action_categories_create"},
		"-/categories/update": {"function": "action_categories_update"},
		"-/categories/delete": {"function": "action_categories_delete"},
		"-/categories/test": {"function": "action_categories_test"},
		"-/topics/list": {"function": "action_topics_list"},
		"-/topics/lookup": {"function": "action_topics_lookup"},
		"-/topics/set_category": {"function": "action_topics_set_category"},
		"-/topics/delete": {"function": "action_topics_delete"},
		"-/destinations/list": {"function": "action_destinations_list"},
		"-/push/vapid": {"function": "action_push_vapid"},
		"-/push/accounts/list": {"function": "action_push_accounts_list"},
		"-/push/accounts/add": {"function": "action_push_accounts_add"},
		"-/push/accounts/remove": {"function": "action_push_accounts_remove"},
		"-/push/register": {"function": "action_push_register"},
		"-/push/register/fcm": {"function": "action_push_register_fcm"},
		"-/push/setup": {"function": "action_push_setup"},
		"-/push/inbound/:sub": {"function": "action_push_inbound", "public": true},
		"-/push/drain": {"function": "action_push_drain"},
		"-/push/ack": {"function": "action_push_ack"}
	},

	"functions": {
		"clear/all": {"function": "function_clear_all"},
		"clear/app": {"function": "function_clear_app"},
		"clear/object": {"function": "function_clear_object"},
		"list": {"function": "function_list"},
		"read": {"function": "function_read"},
		"read/all": {"function": "function_read_all"},
		"expire": {"function": "function_expire"},
		"send": {"function": "function_send"},
		"topics": {"function": "function_topics"},
		"topic/remove": {"function": "function_topic_remove"},
		"categories": {"function": "function_categories", "permission": "notifications/send"},
		"category/list": {"function": "function_category_list"},
		"category/create": {"function": "function_category_create"},
		"category/update": {"function": "function_category_update"},
		"category/delete": {"function": "function_category_delete"},
		"category/test": {"function": "function_category_test"},
		"topic/list": {"function": "function_topic_list"},
		"topic/lookup": {"function": "function_topic_lookup"},
		"topic/set_category": {"function": "function_topic_set_category"},
		"topic/delete": {"function": "function_topic_delete"},
		"destinations/available": {"function": "function_destinations_available"},
		"destinations/add": {"function": "function_destinations_add", "permission": "notifications/send"},
		"accounts/vapid": {"function": "function_accounts_vapid", "permission": "notifications/send"},
		"accounts/list": {"function": "function_accounts_list", "permission": "notifications/send"},
		"accounts/add": {"function": "function_accounts_add", "permission": "notifications/send"},
		"accounts/remove": {"function": "function_accounts_remove", "permission": "notifications/send"},
		"push/register": {"function": "function_push_register", "permission": "notifications/send"},
		"push/register/fcm": {"function": "function_push_register_fcm", "permission": "notifications/send"},
		"push/setup": {"function": "function_push_setup", "permission": "notifications/send"},
		"push/inbound": {"function": "function_push_inbound", "permission": "notifications/send"},
		"push/drain": {"function": "function_push_drain", "permission": "notifications/send"},
		"push/ack": {"function": "function_push_ack", "permission": "notifications/send"}
	}
}
